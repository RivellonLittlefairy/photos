{
  "name": "@timeline/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "import:photos": "tsx src/scripts/import-photos.ts",
    "backfill:stage-month": "tsx src/scripts/backfill-stage-by-month.ts",
    "backfill:content-hash": "tsx src/scripts/backfill-content-hash.ts",
    "reset:data": "tsx src/scripts/reset-data.ts",
    "lint": "echo 'No lint configured for @timeline/server'"
  },
  "dependencies": {
    "@timeline/shared": "0.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exifr": "^7.1.3",
    "express": "^4.21.2",
    "mongoose": "^8.18.0",
    "morgan": "^1.10.0",
    "multer": "^2.1.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^4.17.23",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.4.0",
    "tsx": "^4.20.5"
  }
}
